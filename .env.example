# =====================================================
# Root-level .env  (informational only — actual env vars
# are read from server/.env and client/.env by each workspace).
#
# Local dev defaults: PostgreSQL running on localhost:5432
# with ttm_user / ttm_password / team_task_manager.
# Run `scripts/setup-postgres.ps1` to create them on Windows.
# =====================================================

NODE_ENV=development
DATABASE_URL=postgresql://ttm_user:ttm_password@localhost:5432/team_task_manager?schema=public
