# =====================================================
# Unified server environment variables (Express + Next.js).
# Copy to .env and customize for local development.
# =====================================================

NODE_ENV=development
PORT=4000

# When true (auto-enabled in production), Express also serves the Next.js
# frontend from the same port. Local dev keeps them on separate ports for HMR.
# SERVE_FRONTEND=true

# --- Database (PostgreSQL) ---
DATABASE_URL=postgresql://ttm_user:ttm_password@localhost:5432/team_task_manager?schema=public

# --- JWT ---
JWT_ACCESS_SECRET=replace-with-a-long-random-string-please
JWT_REFRESH_SECRET=replace-with-another-long-random-string
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d

# --- CORS ---
CORS_ORIGIN=http://localhost:3000
CLIENT_URL=http://localhost:3000

# --- Cloudinary ---
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=

# --- Rate Limit ---
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX=300

# --- Logging ---
LOG_LEVEL=info
